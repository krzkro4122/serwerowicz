option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: serwerowicz.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: assets

container_commands:
  01_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py collectstatic --noinput"
    leader_only: true
  02_set_permissions:
      command: "chown -R webapp:webapp /var/app/current/assets"
